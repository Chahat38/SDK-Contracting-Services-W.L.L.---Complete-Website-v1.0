<IfModule mod_rewrite.c>
    RewriteEngine On

    # Remove .php from URL
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?]
    RewriteRule ^ /%1 [R=301,L]

    # Hide .php extension
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^/.]+)$ $1.php [L]
</IfModule>